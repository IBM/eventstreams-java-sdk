{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:recommended'],
  packageRules: [
    {
      matchPackageNames: ['org.apache.kafka:kafka-clients'],
      matchUpdateTypes: ['major'],
      enabled: false,
    },
    {
      description: 'Checkstyle 12.3.1 is the last version to support JDK 11',
      matchPackageNames: ['com.puppycrawl.tools:checkstyle'],
      allowedVersions: '<=12.3.1',
    },
  ],
}
