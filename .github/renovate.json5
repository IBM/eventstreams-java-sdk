{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:recommended'],
  packageRules: [
    {
      description: 'Keep kafka-clients tracking their current major version',
      matchPackageNames: ['org.apache.kafka:kafka-clients'],
      matchUpdateTypes: ['major'],
      enabled: false,
    },
    {
      description: 'Checkstyle 11.0.0 and newer require JDK 17',
      matchPackageNames: ['com.puppycrawl.tools:checkstyle'],
      allowedVersions: '<11.0.0',
    },
  ],
}
